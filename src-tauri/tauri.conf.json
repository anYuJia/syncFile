{
  "$schema": "https://schema.tauri.app/config/2.10",
  "productName": "syncFile",
  "version": "0.0.23",
  "identifier": "com.syncfile.app",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../out/renderer",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "syncFile",
        "width": 800,
        "height": 600,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": null
    }
  },
  "plugins": {}
}
