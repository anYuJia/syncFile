{
  "name": "syncfile",
  "productName": "syncFile",
  "version": "0.0.23",
  "description": "LAN P2P file transfer tool",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "homepage": "https://github.com/anYuJia/syncFile",
  "repository": {
    "type": "git",
    "url": "https://github.com/anYuJia/syncFile.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist:win:ia32": "npm run build && electron-builder --config electron-builder.yml --win nsis --ia32 --publish never",
    "dist:mac:arm64": "npm run build && electron-builder --config electron-builder.yml --mac dmg zip --arm64 --publish never",
    "release:win:ia32": "npm run build && electron-builder --config electron-builder.yml --win nsis --ia32 --publish always",
    "release:mac:arm64": "npm run build && electron-builder --config electron-builder.yml --mac dmg zip --arm64 --publish always",
    "dev:vite": "vite --config vite.config.ts",
    "build:vite": "vite build --config vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "bonjour-service": "^1.2.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.73",
    "@types/react-dom": "^18.2.23",
    "@vitejs/plugin-react": "^5.0.0",
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.4.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
